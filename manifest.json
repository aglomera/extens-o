{
  "manifest_version": 3,
  "name": "Groq Vision",
  "version": "1.0",
  "description": "Tira print da aba atual e analisa com Groq Vision LLM",
  "permissions": ["activeTab", "storage", "tabs"],
  "host_permissions": ["https://api.groq.com/*"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Groq Vision",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
